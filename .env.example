# ============================================================
# LLM
# ============================================================
# Supported: openai / anthropic / gemini / deepseek / qwen / ollama
LLM_PROVIDER=openai

# Chat model name. For SiliconFlow, use an OpenAI-compatible model name.
LLM_MODEL=deepseek-ai/DeepSeek-V4-Flash

# OpenAI-compatible base URL. Leave empty to use the provider default.
LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_TIMEOUT=30
# LLM_MAX_RETRIES=1
# LLM_TRUST_ENV_PROXY=0

# ============================================================
# API keys
# ============================================================
# OpenAI-compatible APIs, SiliconFlow, embeddings, and OCR reuse this key.
OPENAI_API_KEY=sk-xxx

# Provider-specific keys, only needed when LLM_PROVIDER selects them.
# ANTHROPIC_API_KEY=sk-ant-xxx
# GOOGLE_API_KEY=xxx
# DEEPSEEK_API_KEY=sk-xxx
# DASHSCOPE_API_KEY=sk-xxx

# ============================================================
# Embeddings / RAG
# ============================================================
# Uses OpenAI-compatible embeddings API with OPENAI_API_KEY and LLM_BASE_URL.
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_COLLECTION_NAME=knowledge_base_qwen3_embedding_8b
# EMBEDDING_TIMEOUT=30
# EMBEDDING_MAX_RETRIES=1
# RETRIEVAL_CANDIDATE_MULTIPLIER=8
# RETRIEVAL_MAX_RERANK_BONUS=0.6
# RAG_PARENT_CHARS=1200
# RAG_PARENT_OVERLAP_CHARS=200
# RAG_CHILD_CHARS=400
# RAG_CHILD_OVERLAP_CHARS=100
# RAG_TABLE_CHARS=8000
# RAG_ATOMIC_CHARS=3000

# Important: do not mix different embedding models in one Chroma collection.
# After changing EMBEDDING_MODEL, rebuild chroma_db or use a new collection name.

# ============================================================
# OCR / VLM
# ============================================================
OCR_MODEL=deepseek-ai/DeepSeek-OCR
# OCR_TIMEOUT=60

# ============================================================
# Tools
# ============================================================
# Local tools are enabled by default and do not require VPN:
# knowledge_search / list_knowledge_documents / calculator / current_time

# Online tools are disabled by default. Enable only when your network/API is ready.
# ENABLE_ONLINE_TOOLS=0
# ENABLE_WIKIPEDIA_TOOL=0
# ENABLE_ARXIV_TOOL=0
# TAVILY_API_KEY=tvly-xxx

